<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>2 Minute Calm — Prototype</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green-light: #C8E6C9;
    --green-mid:   #A5D6A7;
    --green-deep:  #66BB6A;
    --green-text:  #2E7D32;
    --blue-calm:   #B3D9F2;
    --peach-warm:  #FDDCB0;
    --bg:          #F4F8F4;
    --white:       #FFFFFF;
    --ink:         #1C2B1E;
    --ink-light:   #6B7F6D;
    --shadow:      rgba(44, 90, 48, 0.10);
  }

  body {
    background: #E8EDE8;
    font-family: 'DM Sans', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    min-height: 100vh;
    padding: 32px 16px 48px;
  }

  .lab-header {
    text-align: center;
    margin-bottom: 28px;
  }
  .lab-header h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    color: var(--ink);
    letter-spacing: -0.3px;
  }
  .lab-header p {
    font-size: 13px;
    color: var(--ink-light);
    margin-top: 4px;
  }

  /* Phone shell */
  .phone {
    width: 375px;
    height: 780px;
    background: var(--bg);
    border-radius: 52px;
    box-shadow:
      0 0 0 10px #1a1a1a,
      0 0 0 12px #333,
      0 32px 80px rgba(0,0,0,0.35);
    overflow: hidden;
    position: relative;
  }

  /* Notch */
  .notch {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 120px; height: 30px;
    background: #1a1a1a;
    border-radius: 0 0 20px 20px;
    z-index: 100;
  }

  /* Screens */
  .screen {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    overflow: hidden;
  }
  .screen.active { display: flex; }

  /* ─── SCREEN 1: HOME ─── */
  #home {
    background: var(--bg);
    padding: 48px 28px 32px;
  }

  .home-top {
    margin-top: 24px;
    text-align: center;
  }
  .home-top .app-name {
    font-family: 'DM Serif Display', serif;
    font-size: 34px;
    color: var(--ink);
    letter-spacing: -0.5px;
    line-height: 1.1;
  }
  .home-top .tagline {
    font-size: 15px;
    color: var(--ink-light);
    margin-top: 6px;
    font-weight: 300;
  }

  .streak-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: white;
    border: 1px solid #E0EDE0;
    border-radius: 50px;
    padding: 7px 16px;
    margin: 18px auto 0;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-light);
    box-shadow: 0 2px 8px var(--shadow);
  }
  .streak-badge .flame { font-size: 15px; }

  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    color: var(--ink-light);
    text-transform: uppercase;
    margin: 28px 0 12px;
  }

  .mode-cards { display: flex; flex-direction: column; gap: 12px; }

  .mode-card {
    background: var(--white);
    border-radius: 20px;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 2px 12px var(--shadow);
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    border: 1px solid rgba(255,255,255,0.8);
  }
  .mode-card:active { transform: scale(0.98); }
  .mode-card:hover  { transform: translateY(-1px); box-shadow: 0 6px 20px var(--shadow); }

  .mode-icon {
    width: 52px; height: 52px;
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
  }
  .mode-icon.breathe  { background: #E8F5E9; }
  .mode-icon.meditate { background: #E3F2FD; }
  .mode-icon.standup  { background: #FFF3E0; }

  .mode-info { flex: 1; }
  .mode-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.2px;
  }
  .mode-sub {
    font-size: 12px;
    color: var(--ink-light);
    margin-top: 2px;
    font-weight: 300;
  }
  .mode-chevron { color: #B0BFB0; font-size: 14px; }

  /* ─── SCREEN 2: SESSION ─── */
  #session {
    background: var(--white);
    padding: 0;
    position: relative;
  }

  .session-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 40%, #E8F5E9 0%, #F4F8F4 70%);
  }

  .session-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    padding: 48px 28px 40px;
  }

  .back-btn {
    align-self: flex-start;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 22px;
    color: var(--ink-light);
    margin-top: 8px;
    padding: 4px;
  }

  .session-mode-label {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--green-text);
    margin-top: 16px;
  }

  .session-timer {
    font-family: 'DM Serif Display', serif;
    font-size: 52px;
    color: var(--ink);
    letter-spacing: -1px;
    margin-top: 6px;
    line-height: 1;
  }

  /* Breathing circle */
  .breath-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 28px 0;
  }
  .breath-ring {
    width: 200px; height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, #C8E6C9 0%, #A5D6A7 60%, transparent 100%);
    animation: breathe 4s ease-in-out infinite;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 40px rgba(102, 187, 106, 0.25);
  }
  .breath-inner {
    width: 120px; height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, white 0%, #E8F5E9 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
  }
  @keyframes breathe {
    0%, 100% { transform: scale(0.85); opacity: 0.7; }
    50%       { transform: scale(1.12); opacity: 1; }
  }

  .cue-text {
    font-family: 'DM Serif Display', serif;
    font-size: 26px;
    color: var(--ink);
    text-align: center;
    line-height: 1.3;
    letter-spacing: -0.3px;
    min-height: 68px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .progress-wrap {
    width: 100%;
    margin-top: auto;
  }
  .progress-track {
    width: 100%;
    height: 4px;
    background: #E0EDE0;
    border-radius: 4px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--green-mid), var(--green-deep));
    border-radius: 4px;
    width: 35%;
    transition: width 1s linear;
  }
  .progress-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
    font-size: 12px;
    color: var(--ink-light);
  }

  .end-btn {
    margin-top: 24px;
    width: 100%;
    padding: 16px;
    background: var(--ink);
    color: white;
    border: none;
    border-radius: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.2px;
    transition: opacity 0.2s;
  }
  .end-btn:hover { opacity: 0.85; }

  /* ─── SCREEN 3: COMPLETION ─── */
  #completion {
    background: var(--white);
    position: relative;
    overflow: hidden;
  }
  .completion-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #E8F5E9 0%, #F4F8F4 50%, #FFF8F0 100%);
  }
  .completion-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 48px 32px 40px;
    text-align: center;
  }

  .done-ring {
    width: 100px; height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--green-mid), var(--green-deep));
    display: flex; align-items: center; justify-content: center;
    font-size: 44px;
    box-shadow: 0 8px 32px rgba(102, 187, 106, 0.35);
    animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes popIn {
    from { transform: scale(0); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
  }

  .done-title {
    font-family: 'DM Serif Display', serif;
    font-size: 32px;
    color: var(--ink);
    margin-top: 24px;
    letter-spacing: -0.5px;
    line-height: 1.2;
  }
  .done-sub {
    font-size: 15px;
    color: var(--ink-light);
    margin-top: 10px;
    font-weight: 300;
    line-height: 1.5;
  }

  .streak-card {
    background: white;
    border-radius: 20px;
    padding: 20px 28px;
    margin-top: 28px;
    width: 100%;
    box-shadow: 0 4px 20px var(--shadow);
    border: 1px solid #E8F0E8;
  }
  .streak-card-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    color: var(--ink-light);
    text-transform: uppercase;
  }
  .streak-card-number {
    font-family: 'DM Serif Display', serif;
    font-size: 48px;
    color: var(--green-text);
    line-height: 1;
    margin-top: 4px;
  }
  .streak-card-sub {
    font-size: 13px;
    color: var(--ink-light);
    margin-top: 2px;
  }

  .completion-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    margin-top: 28px;
  }
  .btn-primary {
    padding: 16px;
    background: var(--ink);
    color: white;
    border: none;
    border-radius: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-secondary {
    padding: 14px;
    background: white;
    color: var(--ink);
    border: 1.5px solid #E0EDE0;
    border-radius: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-secondary:hover { background: #F4F8F4; }

  /* ─── SCREEN 4: NOTIFICATION PREVIEW ─── */
  #notif {
    background: #1C1C1E;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 48px 24px 32px;
  }

  .notif-time {
    font-family: 'DM Serif Display', serif;
    font-size: 64px;
    color: white;
    letter-spacing: -2px;
    margin-top: 24px;
    line-height: 1;
  }
  .notif-date {
    font-size: 16px;
    color: rgba(255,255,255,0.5);
    margin-top: 6px;
  }

  .notif-card {
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 16px 18px;
    width: 100%;
    margin-top: 40px;
    display: flex;
    align-items: center;
    gap: 14px;
    border: 1px solid rgba(255,255,255,0.15);
  }
  .notif-app-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--green-mid), var(--green-deep));
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
  }
  .notif-content { flex: 1; }
  .notif-app-name {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.3px;
  }
  .notif-title {
    font-size: 15px;
    font-weight: 600;
    color: white;
    margin-top: 2px;
  }
  .notif-body {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    margin-top: 2px;
  }
  .notif-time-ago {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
  }

  .notif-back {
    margin-top: 40px;
    padding: 14px 32px;
    background: rgba(255,255,255,0.1);
    color: white;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }
  .notif-back:hover { background: rgba(255,255,255,0.18); }

  /* Bottom nav dots */
  .screen-nav {
    display: flex;
    gap: 8px;
    margin-top: 24px;
    justify-content: center;
  }
  .nav-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #B0BFB0;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .nav-dot.active { background: var(--green-deep); transform: scale(1.3); }

  /* Screen label */
  .screen-label {
    font-size: 11px;
    color: var(--ink-light);
    margin-top: 10px;
    font-weight: 500;
    letter-spacing: 0.3px;
    text-align: center;
  }
</style>
</head>
<body>

<div class="lab-header">
  <h1>2 Minute Calm — Interactive Prototype</h1>
  <p>Tap the cards and buttons to navigate between screens</p>
</div>

<div class="phone">
  <div class="notch"></div>

  <!-- ── SCREEN 1: HOME ── -->
  <div class="screen active" id="home">
    <div class="home-top">
      <div class="app-name">2 Minute<br>Calm</div>
      <div class="tagline">Your daily reset.</div>
      <div class="streak-badge">
        <span class="flame">🔥</span>
        <span>3 day streak</span>
      </div>
    </div>

    <div class="section-label">Choose your reset</div>

    <div class="mode-cards">
      <div class="mode-card" onclick="goTo('session', 'breathe')">
        <div class="mode-icon breathe">🌬️</div>
        <div class="mode-info">
          <div class="mode-title">Breathe</div>
          <div class="mode-sub">Guided breathing cycle · 2 min</div>
        </div>
        <div class="mode-chevron">›</div>
      </div>

      <div class="mode-card" onclick="goTo('session', 'meditate')">
        <div class="mode-icon meditate">🧘</div>
        <div class="mode-info">
          <div class="mode-title">Meditate</div>
          <div class="mode-sub">Gentle focus reset · 2 min</div>
        </div>
        <div class="mode-chevron">›</div>
      </div>

      <div class="mode-card" onclick="goTo('session', 'standup')">
        <div class="mode-icon standup">🧍</div>
        <div class="mode-info">
          <div class="mode-title">Stand Up</div>
          <div class="mode-sub">Micro-movement break · 2 min</div>
        </div>
        <div class="mode-chevron">›</div>
      </div>
    </div>

    <div style="margin-top:auto; text-align:center; padding-top:20px;">
      <div style="font-size:12px; color:var(--ink-light); cursor:pointer;" onclick="goTo('notif')">
        🔔 Preview daily notification
      </div>
    </div>
  </div>

  <!-- ── SCREEN 2: SESSION ── -->
  <div class="screen" id="session">
    <div class="session-bg"></div>
    <div class="session-inner">
      <button class="back-btn" onclick="goTo('home')">‹</button>
      <div class="session-mode-label" id="session-mode-label">BREATHE</div>
      <div class="session-timer" id="session-timer">1:42</div>

      <div class="breath-wrap">
        <div class="breath-ring">
          <div class="breath-inner" id="session-icon">🌬️</div>
        </div>
      </div>

      <div class="cue-text" id="cue-text">Breathe in slowly...</div>

      <div class="progress-wrap">
        <div class="progress-track">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <div class="progress-labels">
          <span>0:00</span>
          <span>2:00</span>
        </div>
      </div>

      <button class="end-btn" onclick="goTo('completion')">Complete Session</button>
    </div>
  </div>

  <!-- ── SCREEN 3: COMPLETION ── -->
  <div class="screen" id="completion">
    <div class="completion-bg"></div>
    <div class="completion-inner">
      <div class="done-ring">✓</div>
      <div class="done-title">You did it.</div>
      <div class="done-sub">Two minutes, all yours.<br>That's what consistency looks like.</div>

      <div class="streak-card">
        <div class="streak-card-label">Current Streak</div>
        <div class="streak-card-number">4</div>
        <div class="streak-card-sub">days in a row 🌿</div>
      </div>

      <div class="completion-actions">
        <button class="btn-primary" onclick="goTo('home')">Back to Home</button>
        <button class="btn-secondary">Share this moment ↗</button>
      </div>
    </div>
  </div>

  <!-- ── SCREEN 4: NOTIFICATION ── -->
  <div class="screen" id="notif">
    <div class="notif-time">9:00</div>
    <div class="notif-date">Saturday, March 14</div>

    <div class="notif-card">
      <div class="notif-app-icon">🌿</div>
      <div class="notif-content">
        <div class="notif-app-name">2 MINUTE CALM</div>
        <div class="notif-title">Your 2 minutes are waiting 🌿</div>
        <div class="notif-body">Take your daily reset. You've got this.</div>
      </div>
      <div class="notif-time-ago">now</div>
    </div>

    <button class="notif-back" onclick="goTo('home')">← Back to app</button>
  </div>

</div>

<!-- Navigation dots -->
<div class="screen-nav">
  <div class="nav-dot active" onclick="goTo('home')" title="Home"></div>
  <div class="nav-dot" onclick="goTo('session')" title="Session"></div>
  <div class="nav-dot" onclick="goTo('completion')" title="Completion"></div>
  <div class="nav-dot" onclick="goTo('notif')" title="Notification"></div>
</div>
<div class="screen-label" id="screen-label">🏠 Home Screen</div>

<script>
const screens = ['home', 'session', 'completion', 'notif'];
const labels  = ['🏠 Home Screen', '⏱ Session Screen', '✅ Completion Screen', '🔔 Daily Notification'];

const modeData = {
  breathe:  { label: 'BREATHE',  icon: '🌬️', cues: ['Breathe in slowly...', 'Hold gently...', 'Breathe out fully...', 'Feel the calm.'] },
  meditate: { label: 'MEDITATE', icon: '🧘', cues: ['Close your eyes.', 'Notice your breath.', 'Let thoughts pass by.', 'You are here.'] },
  standup:  { label: 'STAND UP', icon: '🧍', cues: ['Stand up slowly.', 'Roll your shoulders back.', 'Stretch your arms up.', 'Take a deep breath.'] }
};

let cueInterval = null;
let timerInterval = null;
let seconds = 102; // 1:42 start for demo

function goTo(id, mode) {
  // Clear intervals
  clearInterval(cueInterval);
  clearInterval(timerInterval);

  screens.forEach(s => {
    document.getElementById(s).classList.remove('active');
  });
  document.getElementById(id).classList.add('active');

  // Update dots
  document.querySelectorAll('.nav-dot').forEach((d, i) => {
    d.classList.toggle('active', screens[i] === id);
  });
  document.getElementById('screen-label').textContent = labels[screens.indexOf(id)];

  // Session setup
  if (id === 'session') {
    const m = modeData[mode || 'breathe'];
    document.getElementById('session-mode-label').textContent = m.label;
    document.getElementById('session-icon').textContent = m.icon;

    let cueIndex = 0;
    document.getElementById('cue-text').textContent = m.cues[0];
    cueInterval = setInterval(() => {
      cueIndex = (cueIndex + 1) % m.cues.length;
      const el = document.getElementById('cue-text');
      el.style.opacity = 0;
      setTimeout(() => {
        el.textContent = m.cues[cueIndex];
        el.style.transition = 'opacity 0.6s';
        el.style.opacity = 1;
      }, 300);
    }, 3500);

    // Timer countdown
    seconds = 102;
    updateTimer();
    timerInterval = setInterval(() => {
      if (seconds > 0) { seconds--; updateTimer(); }
      else { clearInterval(timerInterval); goTo('completion'); }
    }, 1000);
  }
}

function updateTimer() {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  document.getElementById('session-timer').textContent =
    `${m}:${s.toString().padStart(2, '0')}`;
  const pct = ((120 - seconds) / 120) * 100;
  document.getElementById('progress-fill').style.width = pct + '%';
}
</script>
</body>
</html>
